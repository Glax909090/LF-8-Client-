<Page x:Class="UiDesktopApp_LF8.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Dashboard">

    <ScrollViewer>
        <StackPanel Margin="25">
            <TextBlock Text="PC-NAME: LF8-ADMIN-WORKSTATION" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Margin="0,0,0,25" 
                       Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>

            <WrapPanel>
                <ui:Card Margin="0,0,15,15" Width="320" Padding="20">
                    <StackPanel>
                        <TextBlock Text="📊 Prozessor (CPU)" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <ProgressBar Value="34" Height="10" Foreground="#0078D4"/>
                        <TextBlock Text="Auslastung: 34%" FontSize="12" Margin="0,10,0,0" Foreground="Gray"/>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,15,15" Width="320" Padding="20">
                    <StackPanel>
                        <TextBlock Text="🧠 Arbeitsspeicher (RAM)" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <ProgressBar Value="62" Height="10" Foreground="Orange"/>
                        <TextBlock Text="Belegung: 62%" FontSize="12" Margin="0,10,0,0" Foreground="Gray"/>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,15,15" Width="320" Padding="20">
                    <StackPanel>
                        <TextBlock Text="💾 Festplattenbelegung" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,5">
                            <TextBlock Text="Laufwerk C:\" Foreground="Gray"/>
                            <TextBlock Text="75%" HorizontalAlignment="Right" FontWeight="Bold"/>
                        </Grid>
                        <ProgressBar Value="75" Height="8" Foreground="#0078D4"/>
                        <TextBlock Text="375 GB von 500 GB belegt" FontSize="11" Margin="0,10,0,0" Foreground="Gray"/>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,15,15" Width="320" Padding="20">
                    <StackPanel>
                        <TextBlock Text="⚡ Festplattennutzung" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <TextBlock Text="Lesen: 12.5 MB/s" FontSize="12" Foreground="Gray"/>
                        <TextBlock Text="Schreiben: 4.2 MB/s" FontSize="12" Foreground="Gray" Margin="0,2,0,0"/>
                        <TextBlock Text="Aktivität: Hoch" FontSize="11" Margin="0,8,0,0" Foreground="#0078D4"/>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,15,15" Width="320" Padding="20">
                    <StackPanel>
                        <TextBlock Text="🌐 Ethernet (LAN)" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <ProgressBar Value="45" Height="8" Foreground="Purple"/>
                        <TextBlock Text="Recv: 1.2 Mbps | Send: 300 Kbps" FontSize="11" Margin="0,8,0,0" Foreground="Gray"/>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,15,15" Width="320" Padding="20">
                    <StackPanel>
                        <TextBlock Text="📶 Wi-Fi" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <ProgressBar Value="12" Height="8" Foreground="HotPink"/>
                        <TextBlock Text="Recv: 150 Kbps | Send: 45 Kbps" FontSize="11" Margin="0,8,0,0" Foreground="Gray"/>
                    </StackPanel>
                </ui:Card>
            </WrapPanel>

            <ui:Card Margin="0,20,15,0" Padding="15" Background="#1E1E1E">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <ui:SymbolIcon Symbol="Code24" Foreground="LightGreen" Margin="0,0,10,0"/>
                        <TextBlock Text="System Live-Log" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Background="Black" CornerRadius="4" Padding="10" Height="150">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="[" Foreground="Gray" FontFamily="Consolas" FontSize="12"/>
                                    <TextBlock Text="{Binding ViewModel.CurrentComputerName}" 
                                               Foreground="LightBlue" 
                                               FontFamily="Consolas" 
                                               FontSize="12"/>
                                    <TextBlock Text="] System-Monitor gestartet..." 
                                               Foreground="LightGreen" 
                                               FontFamily="Consolas" 
                                               FontSize="12" 
                                               Margin="5,0,0,0"/>
                                </StackPanel>

                                <TextBlock Text="[INFO] Verbindung zu lokalen Sensoren hergestellt." Foreground="White" FontFamily="Consolas" FontSize="12"/>
                                <TextBlock Text="[WARN] Hohe Auslastung auf Kern 0 erkannt." Foreground="Yellow" FontFamily="Consolas" FontSize="12"/>
                                <TextBlock Text="> _" Foreground="LightGreen" FontFamily="Consolas" FontSize="12"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </ui:Card>

        </StackPanel>
    </ScrollViewer>
</Page>