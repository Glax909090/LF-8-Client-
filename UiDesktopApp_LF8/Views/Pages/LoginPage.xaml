<Page
  x:Class="UiDesktopApp_LF8.Views.Pages.LoginPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:UiDesktopApp_LF8.Views.Pages"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="Login"
  d:DataContext="{d:DesignInstance local:LoginPage, IsDesignTimeCreatable=False}"
  d:DesignHeight="520"
  d:DesignWidth="460"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  mc:Ignorable="d">

    <Grid>
        <Border
      Width="400"
      HorizontalAlignment="Center"
      VerticalAlignment="Center"
      BorderThickness="1"
      CornerRadius="8"
      Padding="48,40">

            <StackPanel VerticalAlignment="Center">

                <!-- Header -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,32">
                    <ui:SymbolIcon
            HorizontalAlignment="Center"
            FontSize="56"
            Symbol="Shield12" />
                    <TextBlock
            Margin="0,16,0,4"
            HorizontalAlignment="Center"
            FontSize="28"
            FontWeight="SemiBold"
            Text="Sign in" />
                    <TextBlock
            HorizontalAlignment="Center"
            Text="Enter your credentials to continue" />
                </StackPanel>

                <!-- Username -->
                <TextBlock
          Margin="0,0,0,8"
          FontWeight="Medium"
          Text="Username" />
                <ui:TextBox
          PlaceholderText="Enter your username"
          Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <!-- Password -->
                <TextBlock
          Margin="0,20,0,8"
          FontWeight="Medium"
          Text="Password" />
                <ui:PasswordBox
          x:Name="PasswordBox"
          PlaceholderText="Enter your password"
          PasswordChanged="PasswordBox_PasswordChanged" />

                <!-- Error Message -->
                <TextBlock
          Margin="0,16,0,0"
          Text="{Binding ErrorMessage}"
          TextWrapping="Wrap"
          Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <!-- Login Button -->
                <ui:Button
          Margin="0,24,0,0"
          Height="42"
          Appearance="Primary"
          Command="{Binding LoginCommand}"
          Content="Sign In"
          FontSize="15"
          FontWeight="Medium"
          IsEnabled="True"/>
                <!-- Loading indicator -->
                <ui:ProgressRing
          Width="24"
          Height="24"
          Margin="0,12,0,0"
          HorizontalAlignment="Center"
          IsIndeterminate="True"
          Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />

            </StackPanel>
        </Border>
    </Grid>
</Page>