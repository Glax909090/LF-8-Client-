<Page
    x:Class="UiDesktopApp_LF8.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:UiDesktopApp_LF8.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="SettingsPage"
    d:DesignHeight="800"
    d:DesignWidth="1200"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Margin="25">
            <TextBlock Text="⚙️ Alert-Konfiguration" FontSize="28" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock Text="Individuelle Schwellenwerte pro System festlegen" Foreground="Gray" Margin="0,0,0,25"/>

            <WrapPanel>
                <ui:Card Width="350" Margin="0,0,15,15" Padding="20">
                    <StackPanel>
                        <Border Background="{ui:ThemeResource SystemAccentColorSecondaryBrush}" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" Margin="0,0,0,10">
                            <TextBlock Text="CLIENT" FontSize="10" FontWeight="Bold" Foreground="White"/>
                        </Border>
                        <TextBlock Text="LF8-ADMIN-PC" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

                        <Grid Margin="0,5">
                            <TextBlock Text="CPU Warnung ab (%)" VerticalAlignment="Center"/>
                            <ui:TextBox Text="90" Width="70" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,5">
                            <TextBlock Text="RAM Warnung ab (%)" VerticalAlignment="Center"/>
                            <ui:TextBox Text="85" Width="70" HorizontalAlignment="Right"/>
                        </Grid>

                        <ui:Button Content="Für ADMIN-PC speichern" 
                                   Appearance="Primary" 
                                   Margin="0,15,0,0" 
                                   HorizontalAlignment="Stretch" 
                                   Icon="Save24"/>
                    </StackPanel>
                </ui:Card>

                <ui:Card Width="350" Margin="0,0,15,15" Padding="20">
                    <StackPanel>
                        <Border Background="#FF8C00" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" Margin="0,0,0,10">
                            <TextBlock Text="SERVER" FontSize="10" FontWeight="Bold" Foreground="White"/>
                        </Border>
                        <TextBlock Text="SQL-DATABASE-01" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

                        <Grid Margin="0,5">
                            <TextBlock Text="CPU Warnung ab (%)" VerticalAlignment="Center"/>
                            <ui:TextBox Text="75" Width="70" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,5">
                            <TextBlock Text="Disk Warnung ab (%)" VerticalAlignment="Center"/>
                            <ui:TextBox Text="95" Width="70" HorizontalAlignment="Right"/>
                        </Grid>

                        <ui:Button Content="Für SQL-SERVER speichern" 
                                   Appearance="Primary" 
                                   Margin="0,15,0,0" 
                                   HorizontalAlignment="Stretch" 
                                   Icon="Save24"/>
                    </StackPanel>
                </ui:Card>

                <ui:Card Width="350" Margin="0,0,15,15" Padding="20">
                    <StackPanel>
                        <Border Background="#28a745" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" Margin="0,0,0,10">
                            <TextBlock Text="WEB-NODE" FontSize="10" FontWeight="Bold" Foreground="White"/>
                        </Border>
                        <TextBlock Text="WEB-SERVER-PROD" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

                        <Grid Margin="0,5">
                            <TextBlock Text="CPU Warnung ab (%)" VerticalAlignment="Center"/>
                            <ui:TextBox Text="80" Width="70" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,5">
                            <TextBlock Text="RAM Warnung ab (%)" VerticalAlignment="Center"/>
                            <ui:TextBox Text="90" Width="70" HorizontalAlignment="Right"/>
                        </Grid>

                        <ui:Button Content="Für WEB-SERVER speichern" 
                                   Appearance="Primary" 
                                   Margin="0,15,0,0" 
                                   HorizontalAlignment="Stretch" 
                                   Icon="Save24"/>
                    </StackPanel>
                </ui:Card>
            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</Page>