<Page
    x:Class="UiDesktopApp_LF8.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:UiDesktopApp_LF8.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="SettingsPage"
    d:DesignHeight="800"
    d:DesignWidth="1200"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d">

    <ScrollViewer>
        <ItemsControl ItemsSource="{Binding Clients}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <ui:Card Width="350" Margin="0,0,15,15" Padding="20">
                        <StackPanel>

                            <Border Background="{ui:ThemeResource SystemAccentColorSecondaryBrush}"
                            CornerRadius="4"
                            Padding="8,4"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,10">
                                <TextBlock Text="CLIENT"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                            </Border>

                            <!-- Bind Name -->
                            <TextBlock Text="{Binding Name}"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                            <Grid Margin="0,5">
                                <TextBlock Text="CPU Warning (%)" VerticalAlignment="Center"/>
                                <ui:TextBox Text="{Binding CpuWarning}" Width="70" HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid Margin="0,5">
                                <TextBlock Text="RAM Warning (%)" VerticalAlignment="Center"/>
                                <ui:TextBox Text="{Binding RamWarning}" Width="70" HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid Margin="0,5">
                                <TextBlock Text="Disk Warning (%)" VerticalAlignment="Center"/>
                                <ui:TextBox Text="{Binding DiskWarning}" Width="70" HorizontalAlignment="Right"/>
                            </Grid>

                            <ui:Button Content="Save"
                               Appearance="Primary"
                               Margin="0,15,0,0"
                               HorizontalAlignment="Stretch"
                               Icon="Save24"
                               Command="{Binding DataContext.SaveClientCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                               CommandParameter="{Binding}"/>
                        </StackPanel>
                    </ui:Card>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</Page>